// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id         Int        @id @default(autoincrement())
  name       String
  slug       String     @unique
  latitude   Float?
  longitude  Float?
  is_active  Boolean    @default(true)
  users      User[]
  products   Product[]
  orders     Order[]
  categories Category[]
}

model User {
  id           Int     @id @default(autoincrement())
  store_id     Int
  client_token String  @unique @default(uuid())
  name         String?
  phone        String  @unique
  username     String? @unique
  password     String?
  role         String  @default("CLIENT") // CLIENT, ADMIN
  store        Store   @relation(fields: [store_id], references: [id])
  orders       Order[]
}

model VerificationCode {
  id         Int      @id @default(autoincrement())
  phone      String
  code       String
  expires_at DateTime

  @@unique([phone, code])
}

model Product {
  id           Int         @id @default(autoincrement())
  store_id     Int
  name         String
  price        Float
  image_url    String?
  is_available Boolean     @default(true)
  description  String?
  stock        Int?
  is_combo     Boolean     @default(false)
  category_id  Int?
  store        Store       @relation(fields: [store_id], references: [id])
  category     Category?   @relation(fields: [category_id], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  comboItems   ComboItem[] @relation("ComboItems")
  partOfCombos ComboItem[] @relation("ProductInCombo")
}

model Order {
  id                Int         @id @default(autoincrement())
  store_id          Int
  user_id           Int
  delivery_address  String
  latitude          Float?
  longitude         Float?
  distance_km       Float?
  estimated_minutes Int?
  total_amount      Float
  payment_method    String // CASH, TRANSFER
  payment_reference String?
  status            String      @default("PENDING") // PENDING, ACCEPTED, DISPATCHED, DELIVERED, CANCELLED
  cancel_reason     String?
  client_rating     Int?
  client_review     String?
  createdAt         DateTime    @default(now())
  store             Store       @relation(fields: [store_id], references: [id])
  user              User        @relation(fields: [user_id], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  unit_price Float
  order      Order   @relation(fields: [order_id], references: [id])
  product    Product @relation(fields: [product_id], references: [id])
}

model ComboItem {
  id         Int     @id @default(autoincrement())
  combo_id   Int
  product_id Int
  quantity   Int     @default(1)
  combo      Product @relation("ComboItems", fields: [combo_id], references: [id])
  product    Product @relation("ProductInCombo", fields: [product_id], references: [id])
}

model Category {
  id        Int       @id @default(autoincrement())
  store_id  Int
  name      String
  image_url String?
  store     Store     @relation(fields: [store_id], references: [id])
  products  Product[]
}
